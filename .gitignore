# ─── sanctum-gitignore-managed (do not edit between markers) ────────────
# Source of truth: ~/.sanctum/templates/sanctum-gitignore.template
# Updated by: ~/.sanctum/scripts/sanctum-gitignore-sync (per repo)
#
# Doctrine: "if it's not in git, it's either gitignored or it doesn't exist."
# No third state. Anything that drifts into "untracked but not ignored" is a
# bug to triage, not a tolerated background condition.
# See operations/2026-04-28-the-clean-stage in sanctum-docs for the full
# rationale.

# OS noise
.DS_Store
Thumbs.db
desktop.ini
.AppleDouble
.LSOverride

# Editor / IDE noise
.vscode/
.idea/
*.swp
*.swo
*~
.\#*
\#*\#

# Python build/runtime
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.venv/
*-venv/
.*-venv/
venv/
env/
.coverage
htmlcov/
build/
dist/

# Node / pnpm / npm — never source of truth
node_modules/
package-lock.json
yarn.lock
.npm/
.pnpm-store/

# Rust / Cargo
**/target/
*.rlib

# Locks / sockets / pids
*.lock
*.sock
*.pid

# Manual snapshots — point-in-time, not source of truth
*.bak
*.bak.*
*.bak-*
*.backup
*.pre-*
*.stale-*
*.orig
*.rej

# Rolling runtime state — regenerated continuously
logs/
metrics/
audit/audit.log
*.log
*.log.[0-9]*
*.jsonl.[0-9]*

# Local databases and binaries
*.db
*.sqlite
*.sqlite3
*.metallib

# OS-level certs / secrets — NEVER commit
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer
*.der
*.keystore
.env
.env.*
!.env.example
credentials/
secrets/

# Auto-generated from upstream tooling
staging/
.cache/
.tmp/
tmp/

# Backups directory — kept locally, never tracked
backups/

# Apple-platform local state
.Spotlight-V100/
.Trashes/
.fseventsd/

# ─── end sanctum-gitignore-managed ──────────────────────────────────────

# build output
dist/
# generated types
.astro/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# environment variables
.env
.env.production

# macOS-specific files
.DS_Store
