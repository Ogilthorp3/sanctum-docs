---
// Hidden CYOA page in joual. Not wired into the sidebar.
// If you found this, you either typed the URL directly, clicked a link from
// /redpill/, or someone whispered it to you. Welcome.
const title = 'Le Livre dont vous êtes le héros — 02h47 dans le sous-sol';
const description = "Une aventure dont tu es le héros. En joual. Dans le haus.";
---
<!doctype html>
<html lang="fr-CA" data-cyoa>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script src="/easter-eggs.js" defer></script>
    <style>
      :root { color-scheme: dark; --ink: #e8dcc0; --ink-dim: #a59881; --accent: #d4952e; --red: #c0392b; --green: #27ae60; }
      * { box-sizing: border-box; }
      html, body {
        margin: 0; padding: 0; min-height: 100vh;
        background: #120e08;
        background-image: radial-gradient(ellipse at top, #1e1610 0%, #0a0705 70%);
        color: var(--ink);
        font-family: 'Newsreader', Georgia, 'Times New Roman', serif;
        font-size: 17px;
        line-height: 1.75;
      }
      main {
        max-width: 680px;
        margin: 0 auto;
        padding: 4rem 1.5rem 6rem;
      }
      header {
        border-bottom: 1px solid rgba(212, 149, 46, 0.25);
        padding-bottom: 1.2rem;
        margin-bottom: 2rem;
      }
      header h1 {
        font-size: clamp(22px, 3.5vw, 34px);
        margin: 0 0 .3rem;
        color: var(--accent);
        letter-spacing: 0.01em;
      }
      header .sub {
        color: var(--ink-dim);
        font-size: 14px;
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        letter-spacing: 0.05em;
      }
      .scene { display: none; }
      .scene.active { display: block; animation: fade 400ms ease; }
      @keyframes fade { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
      .scene h2 {
        color: var(--accent);
        font-size: clamp(19px, 2.4vw, 25px);
        margin: 0 0 1.2rem;
        font-weight: 500;
      }
      p { margin: 0 0 1.1rem; }
      p.stage {
        color: var(--ink-dim);
        font-style: italic;
        font-size: 15px;
        border-left: 2px solid rgba(212, 149, 46, 0.35);
        padding-left: 1rem;
      }
      code {
        font-family: 'JetBrains Mono', ui-monospace, monospace;
        font-size: 0.88em;
        background: rgba(212, 149, 46, 0.08);
        color: #f0c674;
        padding: 1px 6px;
        border-radius: 3px;
      }
      .choices {
        list-style: none;
        padding: 0;
        margin: 1.8rem 0 0;
        display: flex;
        flex-direction: column;
        gap: .6rem;
      }
      .choices a {
        display: block;
        padding: 0.85rem 1.1rem;
        color: var(--ink);
        text-decoration: none;
        border: 1px solid rgba(212, 149, 46, 0.35);
        border-radius: 4px;
        transition: all 180ms;
        font-family: 'Newsreader', serif;
      }
      .choices a:hover {
        border-color: var(--accent);
        background: rgba(212, 149, 46, 0.06);
        transform: translateX(3px);
      }
      .choices a::before {
        content: '▸ ';
        color: var(--accent);
      }
      .ending {
        margin-top: 2rem;
        padding: 1.4rem 1.4rem 1.2rem;
        border: 1px solid rgba(212, 149, 46, 0.25);
        border-radius: 4px;
        background: rgba(0,0,0,0.2);
      }
      .ending .label {
        display: inline-block;
        color: var(--accent);
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        letter-spacing: 0.15em;
        margin-bottom: 0.4rem;
      }
      .ending h3 { margin: 0 0 0.5rem; font-size: 20px; color: var(--ink); font-weight: 500; }
      .ending.good .label { color: var(--green); }
      .ending.good h3 { color: #b9e4c7; }
      .ending.bad .label { color: var(--red); }
      .ending.bad h3 { color: #f0c2bd; }
      .kane {
        display: inline-block;
        margin-top: 0.8rem;
        padding: 7px 13px;
        background: linear-gradient(135deg, #2a0606 0%, #5a0f0f 100%);
        color: #f8d4d0;
        font-family: Impact, 'Arial Black', system-ui, sans-serif;
        font-weight: 900;
        font-size: 14px;
        letter-spacing: 0.14em;
        border: 1px solid rgba(255, 46, 46, 0.45);
        border-radius: 3px;
        text-shadow: 0 0 10px rgba(255, 46, 46, 0.6);
        box-shadow: 0 0 18px rgba(139, 0, 0, 0.55), inset 0 0 12px rgba(0, 0, 0, 0.6);
      }
      .restart {
        display: inline-block;
        margin-top: 1rem;
        color: var(--ink-dim);
        text-decoration: none;
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        padding: 6px 10px;
        border: 1px dashed rgba(212, 149, 46, 0.4);
        border-radius: 3px;
      }
      .restart:hover { color: var(--accent); border-color: var(--accent); }
      footer { margin-top: 3rem; color: var(--ink-dim); font-size: 13px; font-family: 'JetBrains Mono', monospace; border-top: 1px dashed rgba(212, 149, 46, 0.2); padding-top: 1.2rem; }
      footer a { color: var(--accent); text-decoration: underline dotted rgba(212, 149, 46, 0.4); }
      @media (prefers-reduced-motion: reduce) {
        .scene.active { animation: none; }
        .choices a:hover { transform: none; }
      }
    </style>
  </head>
  <body>
    <main>
      <header>
        <h1>Le Livre dont vous êtes le héros</h1>
        <div class="sub">chapitre 1 · <code>02h47</code> dans le sous-sol</div>
      </header>

      <!-- ─────────────────────────── Scène 1 ─────────────────────────── -->
      <section class="scene" id="scene-1">
        <p class="stage">Mardi, 02h47 du matin. T'es debout dans la cuisine parce que t'avais soif. Ton iPhone a beepé une fois, pis s'est fermé la gueule. Le dashboard du <code>command-center</code> sur <code>:1111</code> est ouvert sur ton laptop, à l'autre boutte du comptoir. Tu y jettes un coup d'œil.</p>

        <p>Le Xbox du sous-sol vient d'apparaître sur le Wi-Fi. Le curfew a commencé à 23h00. Albert était supposé dormir depuis quatre heures. Le screen-time a essayé de couper la game, pis le Xbox s'est reconnecté. Tout seul. Trois fois.</p>

        <p>Ta femme dort. Le chat dort. La ville dort. Le watchdog, lui, ne dort pas — c'est pour ça qu'y existe. Mais là, c'est toi qui dois décider quoi faire astheure.</p>

        <p><strong>Qu'est-ce que tu fais?</strong></p>

        <ul class="choices">
          <li><a href="#scene-laisse">Tu laisses faire. C'est probablement juste le firmware qui se met à jour. Tu retournes te coucher.</a></li>
          <li><a href="#scene-yoda">Tu ouvres Signal pis tu textes à Yoda: <code>what's going on in the basement?</code></a></li>
          <li><a href="#scene-status">Tu vérifies <code>/screen/status</code> sur force-flow avant de faire quoi que ce soit. Mesurer avant de couper.</a></li>
        </ul>
      </section>

      <!-- ─────────────────────────── Scène LAISSER FAIRE ─────────────────────────── -->
      <section class="scene" id="scene-laisse">
        <h2>Tu laisses faire.</h2>

        <p class="stage">Tu refermes ton laptop. Tu remontes. Tu te recouches. T'entends le ventilateur du Mac Mini au loin, son petit bruit constant qui t'a toujours rassuré.</p>

        <p>03h42. Le Sonos du premier étage se met à cracher un message TTS en voix clonée de Yoda, à plein volume:</p>

        <p class="stage">« Cascade failure detected. Bridge100 reports no route to host. Twenty-two services are in <code>spawn scheduled</code> and nobody is spawning. The dashboard is red from one end to the other. »</p>

        <p>Ta femme se réveille. Le chat saute du lit. La lumière s'allume dans la chambre d'Albert, qui se demande pourquoi sa console vient de mourir pour de bon. T'ouvres ton laptop en panique. Windu a bloqué trois MACs d'un coup. Qui-Gon est en train d'essayer de redémarrer Docker qui refuse de coopérer. Le <code>usage.jsonl</code> est rempli de <code>provider_unhealthy</code> pour les quinze dernières minutes.</p>

        <p>T'as pas suivi la game, là y'é tard pour changer de ligne.</p>

        <div class="ending bad">
          <span class="label">FIN · MAUVAISE</span>
          <h3>Ça brasse en tabarnak.</h3>
          <p>T'as un incident à 04h du matin en pyjama, pis t'as pas d'excuse parce que tu l'as vu venir. La Living Force te pardonne. Ta blonde, moins.</p>
          <span class="kane">✦ KANE LIVES. ✦</span>
          <p style="margin-top: 0.8rem; margin-bottom: 0;"><em>Sur le Sonos du premier étage, la voix synthétisée de Yoda cède la place, pour un court instant, à une autre voix — plus calme, plus sourde, plus certaine: <strong>"You cannot kill what will not die."</strong> Personne a configuré ce sample-là. Personne l'a mis dans les service YAMLs. Kane vit dans le tiberium du cache. Ton dashboard a la couleur du sang séché pis du 04h00 du matin.</em></p>
        </div>

        <a class="restart" href="#scene-1">↺ Recommencer</a>
      </section>

      <!-- ─────────────────────────── Scène YODA ─────────────────────────── -->
      <section class="scene" id="scene-yoda">
        <h2>Tu textes Yoda.</h2>

        <p class="stage">Tu lui envoies un message sur Signal à <code>+15555550100</code>. Quatre secondes plus tard, il répond. C'est pas normalement cette vitesse-là — les <em>brainy questions</em> passent par <code>council-max-thinking</code>, qui est Opus 4.7 avec <code>--effort max</code> via ton abonnement Claude Team. Ça pense dur.</p>

        <p class="stage">Yoda (Signal, 02h47:31):</p>

        <p class="stage">« The Xbox (MAC <code>48:F1:EB:E5:0D:CA</code>) came online at 02:47:03. <code>screen_time.py</code> flagged it as a curfew violation (23:00–10:00 weekday window). Force Flow paused it via the Firewalla bridge at 02:47:04. It reconnected three times. Each reconnection was re-paused within 900ms. Windu logged it. No cascade. Want me to block the MAC through Orbi access-control directly so it stops retrying, or let <code>screen_time.py</code> keep the pressure on until morning? »</p>

        <p>Tu réponds: <code>block it</code>. Trois secondes plus tard, l'Orbi a le MAC dans la blacklist. Le Xbox ne se reconnectera plus jusqu'à demain matin.</p>

        <p>Tu remontes te coucher. Le matin, Albert te demande pourquoi sa console marche pu. Tu sirotes ton café en regardant dehors. « Dors donc, mon boy. »</p>

        <div class="ending good">
          <span class="label">FIN · EXCELLENTE</span>
          <h3>C'est ça, être consigliere du haus.</h3>
          <p>T'as délégué au bon agent, tu lui as faite confiance, tu lui as donné une instruction claire, pis t'as retourné te coucher. Le Parrain serait fier. Patrick Roy aussi — glove save, clin d'œil, ligne suivante.</p>
        </div>

        <a class="restart" href="#scene-1">↺ Recommencer</a>
      </section>

      <!-- ─────────────────────────── Scène STATUS ─────────────────────────── -->
      <section class="scene" id="scene-status">
        <h2>Tu vérifies <code>/screen/status</code>.</h2>

        <p class="stage">T'ouvres un terminal. <code>curl -s http://manoir.local:4077/screen/status | jq</code>. La réponse revient en 40ms. Elle dit:</p>

        <pre style="background: rgba(212, 149, 46, 0.06); padding: 1rem; border-radius: 4px; font-size: 13px; overflow-x: auto; font-family: 'JetBrains Mono', monospace; color: var(--ink);" set:html={`&#123;
  "devices": &#123;
    "vrvana-pc":     &#123; "state": "paused", "since": "23:30" &#125;,
    "xbox-basement": &#123; "state": "retrying",
                       "last_block": "02:47:04",
                       "attempts": 3,
                       "next_retry_blocked_until": "09:00" &#125;,
    "apple-tv-1":    &#123; "state": "paused", "since": "22:00" &#125;
  &#125;,
  "force_flow": &#123; "status": "healthy", "queue_depth": 0 &#125;,
  "firewalla":  &#123; "status": "healthy", "port": 1984 &#125;
&#125;`}></pre>

        <p>T'as vu ce que tu voulais voir. Le screen-time a faite sa job. Windu fait sa job. Force Flow fait sa job. Le Xbox s'acharne à se reconnecter, pis à chaque fois il mange une claque de <code>iptables</code> en moins de 900ms. Le dashboard est vert. Le <code>usage.jsonl</code> est tranquille.</p>

        <p>Tu souris. Tu referme le laptop. Tu remontes te coucher. Il est dangereux d'y aller seul — t'es pas seul. T'as 38 services en-dessous de toi qui font le chiffre de nuit.</p>

        <div class="ending good">
          <span class="label">FIN · PARFAITE · SHUTOUT</span>
          <h3>T'as mesuré avant de couper.</h3>
          <p>C'est la meilleure fin. Tu t'es pas paniqué. T'as pas réveillé personne. T'as pas touché à rien que tu comprenais pas. T'as lu le state, t'as vu que c'est sous contrôle, pis t'as retourné te coucher.</p>
          <p>Tu sirotes ton café le matin. Albert demande pourquoi le Xbox marchait pas. Tu réponds: <em>tout sauf de l'ostie de root beer</em>. Il comprend pas. Un jour il comprendra.</p>
        </div>

        <a class="restart" href="#scene-1">↺ Recommencer</a>
      </section>

      <footer>
        <p>Cette page n'apparaît nulle part dans le sidebar. Tu l'as trouvée en tapant l'URL, en suivant un lien de <a href="/redpill/">/redpill/</a>, ou parce que quelqu'un t'a whisperé le chemin.</p>
        <p>Le scénario est réel. Les chiffres, les MACs, les commandes, les endpoints — tout marche comme c'est écrit. Le seul personnage fictif, c'est la version de toi-même qui te lève à 02h47 avec du remords au lieu de du café.</p>
      </footer>
    </main>

    <script>
      // Tiny hash-based state machine. Shows the scene matching the URL hash,
      // falls back to Scene 1. Also bumps focus to the active section so
      // screen readers pick up the story change.
      (function () {
        function showScene() {
          const hash = (location.hash || '#scene-1').slice(1);
          const scenes = document.querySelectorAll('.scene');
          let found = false;
          scenes.forEach((s) => {
            const active = s.id === hash;
            s.classList.toggle('active', active);
            if (active) {
              found = true;
              try { s.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch (e) {}
              const h2 = s.querySelector('h2');
              if (h2) h2.setAttribute('tabindex', '-1');
              if (h2 && h2.focus) h2.focus({ preventScroll: true });
            }
          });
          if (!found) {
            const first = document.getElementById('scene-1');
            if (first) first.classList.add('active');
          }
        }
        window.addEventListener('hashchange', showScene);
        window.addEventListener('load', showScene);
        showScene();
      })();
    </script>
  </body>
</html>
