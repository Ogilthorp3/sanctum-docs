---
interface Props {
  src: string;
  alt: string;
}
const { src, alt } = Astro.props;
---

<div class="zoom-wrapper">
  <img src={src} alt={alt} class="zoom-img" />
  <div class="zoom-hint">🔍 Hover to zoom</div>
</div>

<style>
  .zoom-wrapper {
    position: relative;
    overflow: hidden;
    border-radius: 8px;
    cursor: zoom-in;
    margin: 1.5rem 0;
  }

  .zoom-img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.3s ease;
    transform-origin: center center;
  }

  .zoom-wrapper:hover .zoom-img {
    transform: scale(1.8);
  }

  .zoom-hint {
    position: absolute;
    bottom: 8px;
    right: 12px;
    font-size: 0.75rem;
    opacity: 0.5;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }

  .zoom-wrapper:hover .zoom-hint {
    opacity: 0;
  }
</style>

<script>
  document.querySelectorAll('.zoom-wrapper').forEach((wrapper) => {
    const img = wrapper.querySelector('.zoom-img') as HTMLImageElement;
    if (!img) return;

    wrapper.addEventListener('mousemove', (e) => {
      const event = e as MouseEvent;
      const rect = wrapper.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * 100;
      const y = ((event.clientY - rect.top) / rect.height) * 100;
      img.style.transformOrigin = `${x}% ${y}%`;
    });
  });
</script>
