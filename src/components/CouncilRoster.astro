---
// CouncilRoster — single source-of-truth view of who runs on which model.
//
// Reads `src/data/council-roster.json`, which is regenerated by
// `pnpm refresh:council` (script: scripts/refresh-council-roster.mjs)
// from the live Mini config (~/.openclaw/openclaw.json +
// ~/.sanctum/sanctum-proxy/config.yaml). Any time the champion model
// for a Jedi changes, run `pnpm refresh:council` and commit the JSON;
// every page using this component re-renders on the next deploy.
//
// Variants:
//   <CouncilRoster />               full table — for the canonical
//                                   /architecture/agents page and
//                                   doctrine pages where the full
//                                   roster is the subject.
//   <CouncilRoster variant="compact" />   one-line-per-agent list with
//                                   logical-model and provider only,
//                                   for embed in flowing prose.
//   <CouncilRoster variant="inline" />    natural-language sentence —
//                                   "Yoda + Mundi on Opus, Qui-Gon +
//                                   Cilghal on Qwen, Windu on Gemini" —
//                                   regenerated from the data, so no
//                                   manual prose to drift.
//
// Doctrine: never hardcode Jedi→model assignments in a doc page. Always
// embed this component (or link to /architecture/agents). When the
// roster changes, ONE file changes (council-roster.json) and every
// page automatically reflects the new champion. The "find a way to
// have it only at one page" ask of 2026-05-18 lives in this contract.
import roster from '../data/council-roster.json';

interface Props {
  /**
   * "full" (default): table with logical model + provider + resolved API model
   * "compact": tighter table with logical model + provider only
   * "inline": natural-sentence summary grouped by model family
   */
  variant?: 'full' | 'compact' | 'inline';
  /** Show the "Generated from X at Y" footer (default: true for full/compact) */
  showSource?: boolean;
}

const { variant = 'full', showSource } = Astro.props as Props;
const includeSource = showSource ?? variant !== 'inline';

// Group agents by their api_model for the inline variant.
type Agent = (typeof roster.agents)[number];
const grouped = roster.agents.reduce((acc: Record<string, Agent[]>, a) => {
  const key = a.api_model || a.provider_label || 'unknown';
  (acc[key] = acc[key] || []).push(a);
  return acc;
}, {});
---

{variant === 'full' && (
  <>
    <table>
      <thead>
        <tr>
          <th>Agent</th>
          <th>Logical model</th>
          <th>Provider</th>
          <th>Resolved model</th>
        </tr>
      </thead>
      <tbody>
        {roster.agents.map((a) => (
          <tr>
            <td><strong>{a.label}</strong></td>
            <td><code>{a.logical_model}</code></td>
            <td>{a.provider_label}</td>
            <td><code>{a.api_model}</code></td>
          </tr>
        ))}
      </tbody>
    </table>
  </>
)}

{variant === 'compact' && (
  <table>
    <thead>
      <tr>
        <th>Agent</th>
        <th>Model</th>
        <th>Provider</th>
      </tr>
    </thead>
    <tbody>
      {roster.agents.map((a) => (
        <tr>
          <td><strong>{a.label}</strong></td>
          <td><code>{a.api_model}</code></td>
          <td>{a.provider_label}</td>
        </tr>
      ))}
    </tbody>
  </table>
)}

{variant === 'inline' && (
  <p>
    The Council is plural on purpose — different Jedi run on
    different model families so a single prior can't dominate the
    synthesis. As of last roster refresh:{' '}
    {Object.entries(grouped).map(([model, agents], i, arr) => (
      <>
        <strong>{agents.map((a) => a.label).join(' + ')}</strong>
        {' on '}<code>{model}</code>
        {i < arr.length - 1 ? (i === arr.length - 2 ? ', and ' : ', ') : '.'}
      </>
    ))}
    {' '}See <a href="/architecture/agents/#the-council">the full Council roster</a>
    {' '}for the table with provider URLs and fallbacks.
  </p>
)}

{includeSource && (
  <div style="font-size: 0.85em; opacity: 0.7; margin-top: -0.5em">
    Generated from <code>openclaw.json</code> + <code>sanctum-proxy/config.yaml</code> at{' '}
    <code>{roster.generated_at}</code>. Every Jedi falls back to the
    local Qwen tier if their primary path fails. Refresh via{' '}
    <code>pnpm refresh:council</code>.
  </div>
)}
